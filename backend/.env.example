# ─────────────────────────────────────────────
#  Jira Connection Settings
# ─────────────────────────────────────────────
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_api_token_here

# ─────────────────────────────────────────────
#  Project / Board Settings
#  JIRA_PROJECT_KEY  : the short key shown in every issue number
#                      e.g.  FIZ  →  issues are  FIZ-43429
#  JIRA_BOARD_ID     : numeric id in the board URL
#                      …/jira/software/projects/FIZ/boards/123
#                      set to 0 if you don't use the board endpoint
# ─────────────────────────────────────────────
JIRA_PROJECT_KEY=FIZ
JIRA_BOARD_ID=0

# ─────────────────────────────────────────────
#  LLM Settings
# ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
HIGH_CONFIDENCE_THRESHOLD=90

# ─────────────────────────────────────────────
#  Flask / Deployment
# ─────────────────────────────────────────────
FLASK_DEBUG=0
# Railway injects PORT automatically — leave blank for local (defaults to 5001)
# PORT=5001

# ─────────────────────────────────────────────
#  CORS
#  Add your Vercel deployment URL alongside localhost
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ─────────────────────────────────────────────
#  Scheduler  (Asia/Colombo timezone)
# ─────────────────────────────────────────────
SCHEDULE_TIMES=08:00,10:45,13:00

# ─────────────────────────────────────────────
#  Jira Write  (disabled by default)
#  Set JIRA_WRITE_ENABLED=1 to post comments and move tickets to GCLZ
# ─────────────────────────────────────────────
JIRA_WRITE_ENABLED=0
# JIRA_COMMENT_EMAIL=bot@company.com
# JIRA_COMMENT_API_TOKEN=your_bot_token
# JIRA_TARGET_PROJECT=GCLZ
# JIRA_AI_BOARD_FIELD_ID=customfield_xxxxx

# ─────────────────────────────────────────────
#  Webhook Settings  (auto-classify on ticket create/update)
# ─────────────────────────────────────────────
JIRA_WEBHOOK_SECRET=your_webhook_secret_here

# Rate limiting (requests per minute per IP). 0 = disabled.
RATE_LIMIT_CHAT=20
RATE_LIMIT_SYNC=5
